def create_key_table(key):
    key = key.upper().replace("J", "I")
    table = []

    # Add key letters
    for ch in key:
        if ch not in table and ch.isalpha():
            table.append(ch)
   # Add remaining letters
    for ch in "ABCDEFGHIKLMNOPQRSTUVWXYZ":  # J is excluded
        if ch not in table:
            table.append(ch)

    # Convert to 5x5 matrix
    return [table[i:i+5] for i in range(0, 25, 5)]


def find_position(matrix, ch):
    for i in range(5):
        for j in range(5):
            if matrix[i][j] == ch:
                return i, j

def prepare_text(plaintext):
    plaintext = plaintext.upper().replace(" ", "").replace("J", "I")
    pairs = []
    i = 0

    while i < len(plaintext):
        a = plaintext[i]
        if i + 1 < len(plaintext):
            b = plaintext[i + 1]
            if a != b:
                pairs.append(a + b)
                i += 2
            else:
                pairs.append(a + "X")
                i += 1
        else:
            pairs.append(a + "X")
            i += 1

    return pairs
